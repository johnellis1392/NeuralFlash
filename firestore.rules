rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /cards/{cardId} {
      allow read: if isSignedIn();
      // Allow seeding if the user is authenticated. 
      // In a production app, this would be restricted to admins.
      allow create: if isSignedIn();
    }

    match /userProgress/{progressId} {
      // Create: user must set their own UID
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // Update: user must own the existing document and maintain their UID
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      
      // Read & Delete: user must own the document
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
